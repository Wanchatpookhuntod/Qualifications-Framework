# Copy to .env and fill in real values. Never commit the populated .env file.

# Flask
# Required in production. In dev, an insecure fallback is used with a warning.
# Production: SECRET_KEY is stored in Google Secret Manager (tqf-secret-key)
#             and mounted via --update-secrets in deploy.sh — do NOT set it here.
SECRET_KEY=change-me-to-a-long-random-hex-string
FLASK_ENV=development
FLASK_DEBUG=1

# Dev server bind (used by `python app.py`)
HOST=127.0.0.1
PORT=5001

# Firestore service account.
# Resolution order in firestore_db.py:
#   1. GOOGLE_APPLICATION_CREDENTIALS env var (path to JSON key)
#   2. Application Default Credentials (gcloud auth)
#   3. instance/qualificationsframework-*.json fallback
GOOGLE_APPLICATION_CREDENTIALS=./instance/qualificationsframework-XXXXXXXXXXXX.json
